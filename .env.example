# ============================================================
# FACTO 8 Automation Framework - Variables de entorno
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees .env con credenciales reales al repositorio.
# ============================================================

# === ENTORNO ===
# Opciones: dev | staging | prod
ENVIRONMENT=dev

# === URLs base por entorno ===
# TODO: Reemplazar con URLs reales del portal FACTO
BASE_URL_DEV=https://dev.factoportal.ejemplo.com
BASE_URL_STAGING=https://staging.factoportal.ejemplo.com
BASE_URL_PROD=https://www.factoportal.ejemplo.com

# URL activa (se usa cuando ENVIRONMENT no tiene mapeo explícito)
BASE_URL=https://dev.factoportal.ejemplo.com

# === CREDENCIALES ===
# IMPORTANTE: No usar credenciales de producción en pruebas
USERNAME=usuario_qa@empresa.com
PASSWORD=password_seguro_aqui

# === NAVEGADOR ===
# Opciones: chrome (firefox pendiente de implementación)
BROWSER=chrome

# Modo headless (true para CI/CD/Docker, false para desarrollo local)
HEADLESS=false

# === TIMEOUTS (segundos) ===
TIMEOUT=30
DOWNLOAD_TIMEOUT=60

# === DIRECTORIOS DE SALIDA ===
# Directorio raíz para todos los outputs del framework
OUTPUT_DIR=outputs

# === ALLURE REPORTING ===
ALLURE_RESULTS_DIR=allure-results

# === LOGGING ===
# Opciones: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
