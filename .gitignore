# ============================================================
# FACTO 8 Automation Framework - .gitignore
# ============================================================

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc
*.pyo

# === Entornos virtuales ===
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.conda/

# === Credenciales y configuración sensible ===
.env
*.env.local
*.env.*.local
secrets.json
credentials.json

# === Outputs del framework (generados en ejecución) ===
outputs/screenshots/*
outputs/pdf/*
outputs/xml/*
outputs/logs/*
outputs/json/*
outputs/zip/*
!outputs/screenshots/.gitkeep
!outputs/pdf/.gitkeep
!outputs/xml/.gitkeep
!outputs/logs/.gitkeep
!outputs/json/.gitkeep
!outputs/zip/.gitkeep

# === Allure ===
allure-results/
allure-report/

# === pytest ===
.pytest_cache/
pytest_cache/
.cache/
htmlcov/
.coverage
coverage.xml
*.cover

# === IDEs ===
.idea/
.vscode/
*.swp
*.swo
*~

# === macOS ===
.DS_Store
.AppleDouble
.LSOverride
Spotlight-V100
.Trashes

# === Windows ===
Thumbs.db
ehthumbs.db
Desktop.ini

# === Datos dinámicos de ejecución ===
tests/test_data/dynamic/execution_context.json
