# =============================================================================
# cloudrun.env.example - Variables de entorno para Cloud Run / Docker
# =============================================================================
# Copiar como .env o inyectar como variables de entorno en Cloud Run.
# NUNCA subir valores reales a control de versiones.
# =============================================================================

# ---------------------------------------------------------------------------
# Configuración del portal FACTO 8
# ---------------------------------------------------------------------------
FACTO_URL=https://facto8.ejemplo.com
FACTO_USER=usuario@empresa.com
FACTO_PASSWORD=REEMPLAZAR_CONTRASEÑA
ENVIRONMENT=staging

# ---------------------------------------------------------------------------
# Configuración del navegador
# ---------------------------------------------------------------------------
BROWSER=chrome
HEADLESS=true
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080
PAGE_LOAD_TIMEOUT=30
IMPLICIT_WAIT=10
EXPLICIT_WAIT=20

# ---------------------------------------------------------------------------
# Suite a ejecutar (ver entrypoint.sh para valores válidos)
# smoke | factura | nota_credito | ppd | complemento_pago | adenda | end_to_end | all
# ---------------------------------------------------------------------------
TEST_SUITE=smoke

# ---------------------------------------------------------------------------
# Rutas de salida
# ---------------------------------------------------------------------------
OUTPUT_DIR=/app/outputs
ALLURE_RESULTS_DIR=/app/allure-results

# ---------------------------------------------------------------------------
# Cloud Storage (opcional - para guardar resultados en GCS)
# ---------------------------------------------------------------------------
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# ---------------------------------------------------------------------------
# Notificaciones (opcional)
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
EMAIL_NOTIFICACION=

# ---------------------------------------------------------------------------
# Timeouts y reintentos
# ---------------------------------------------------------------------------
MAX_RETRY_ATTEMPTS=3
RETRY_WAIT_SECONDS=2
DOWNLOAD_TIMEOUT_SECONDS=60
